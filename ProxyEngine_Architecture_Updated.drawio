          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="anj8r9etqsJZ6B1hXlaY-36" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;spacing=8;" value="EvidenceTrace Fields:&#10;- isin, year, exec_id&#10;- size_elasticity (beta ≈ 0.3)&#10;- reach_ratio&#10;- lti_sti_balance&#10;- asymmetric_ratchet_beta&#10;- opting_out_flag" vertex="1">
          <mxGeometry height="160" width="220" x="580" y="730" as="geometry" />
        </mxCell>
        <mxCell id="anj8r9etqsJZ6B1hXlaY-37" edge="1" parent="1" source="anj8r9etqsJZ6B1hXlaY-23" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" target="anj8r9etqsJZ6B1hXlaY-36">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Clustering" vertex="1">
          <mxGeometry height="60" width="117.5" x="402.5" y="200" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-11" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;span style=&quot;font-size: 7px;&quot;&gt;We create a peer group for the selected company. This groups data is used to calculate metrics and do predictions&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="410" y="270" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-12" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;Input Layer constraint:&lt;/b&gt;&lt;br&gt;PDF upload POC strictly parses standard components (salary, STI, LTI) into our schema. This prevents LLM hallucination and grounds the analysis.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="257.5" y="390" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-13" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;Math constraint:&lt;/b&gt;&lt;br&gt;We do not cluster on arbitrary industry labels. We use K-Means on objective ORBIS fundamentals (opre, roa, gear) to find True Shadow Peers.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="410" y="390" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-14" parent="1" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;" value="ProxyEngine — Deterministic SML &amp; Dual-Lens Architecture" vertex="1">
          <mxGeometry height="40" width="800" x="27.5" y="30" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Generate Intermediate Metrics" vertex="1">
          <mxGeometry height="60" width="117.5" x="550" y="200" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-17" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;span style=&quot;font-size: 7px;&quot;&gt;Based on the grouping we compute a wide range of metrics to be used as a decision basis.&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 7px;&quot;&gt;e.g. Averages inside the group. Ratios, Time series developments&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="112.5" width="112.5" x="547.5" y="270" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-18" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;SML constraint:&lt;/b&gt;&lt;br&gt;Lasso-Regularized Quantile Regressions calculate the expected pay curve. The residual translates into the mathematically proven &amp;#39;Reach&amp;#39; ratio.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="547.5" y="390" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-19" edge="1" parent="1" source="WM4isf5iBtK8rN7JYO4I-7" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="WM4isf5iBtK8rN7JYO4I-10" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="430" y="350" as="sourcePoint" />
            <mxPoint x="480" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-20" edge="1" parent="1" source="WM4isf5iBtK8rN7JYO4I-10" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="WM4isf5iBtK8rN7JYO4I-16" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="430" y="350" as="sourcePoint" />
            <mxPoint x="480" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-34" edge="1" parent="1" source="WM4isf5iBtK8rN7JYO4I-21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="WM4isf5iBtK8rN7JYO4I-26" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-21" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Query Creation" vertex="1">
          <mxGeometry height="60" width="117.5" x="710" y="200" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-22" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;span style=&quot;font-size: 7px;&quot;&gt;The user selects questions and options that specify what they care about concerning the audit.&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 7px;&quot;&gt;E.g. legal compliance, Enviromental related incentives, Long-Term variable component focus...&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="717.5" y="270" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-23" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;The Scope Lock:&lt;/b&gt;&lt;br&gt;We do NOT support an open-ended chatbot. The system is restricted to evaluating predefined legal anomalies (e.g. Asymmetric Ratchets, § 87 AktG).&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="717.5" y="390" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-24" edge="1" parent="1" source="WM4isf5iBtK8rN7JYO4I-16" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="WM4isf5iBtK8rN7JYO4I-21" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="670" y="380" as="sourcePoint" />
            <mxPoint x="720" y="330" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Creating JSON Context Payload" vertex="1">
          <mxGeometry height="60" width="117.5" x="867.5" y="200" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-27" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;The Payload needs to include all metrics which are usefull to answer the&amp;nbsp; query. It also includes the query information as well (questions, value statements)&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="867.5" y="270" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-28" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;EvidenceTrace Contract:&lt;/b&gt;&lt;br&gt;The backend generates a strict JSON payload of numeric anomalies. The LLM reads only this payload, ensuring a verifiable audit trail.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="867.5" y="390" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-29" edge="1" parent="1" source="WM4isf5iBtK8rN7JYO4I-5" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0;exitDx=0;exitDy=27.5;exitPerimeter=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="WM4isf5iBtK8rN7JYO4I-16" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <Array as="points">
              <mxPoint x="230" y="180" />
              <mxPoint x="410" y="170" />
            </Array>
            <mxPoint x="140" y="500" as="sourcePoint" />
            <mxPoint x="190" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-30" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="WM4isf5iBtK8rN7JYO4I-10" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="410" y="170" as="sourcePoint" />
            <mxPoint x="540" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-31" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Uses" vertex="1">
          <mxGeometry height="30" width="70" x="310" y="140" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Fine Tuning and system prompting a thinking LLM to perform the task&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="810" y="10" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-33" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="WM4isf5iBtK8rN7JYO4I-26" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="830" y="230" as="sourcePoint" />
            <mxPoint x="850" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-36" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="LLM provides structured audit answer" vertex="1">
          <mxGeometry height="60" width="117.5" x="1020" y="200" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-38" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;The Dual-Lens Engine:&lt;/b&gt;&lt;br&gt;The LLM acts as a deterministic translator, dynamically switching between an Activist Auditor persona and a Corporate Defender persona.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="1023.75" y="390" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-39" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;font style=&quot;font-size: 7px;&quot;&gt;The LLM answers the questions based on the provided context. It referncecs it sources and provides understandable reasoning. It provides a final approve/dissaprove recommendation (Or scale ?)&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="1023.75" y="270" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-40" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;b&gt;The Wargaming Output:&lt;/b&gt;&lt;br&gt;Instead of generic metrics, the dashboard displays actionable, Say-on-Pay voting recommendations directly aligned with ISS / Glass Lewis heuristics.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="1163.75" y="390" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-41" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;font style=&quot;font-size: 9px;&quot;&gt;We visualize relevant information about the proposed pay package and comparative data / metrics. This uses the intermediate data&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="110" x="1163.75" y="270" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-42" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Dashboard accompanying final output" vertex="1">
          <mxGeometry height="60" width="117.5" x="1160" y="200" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-45" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Final report output" vertex="1">
