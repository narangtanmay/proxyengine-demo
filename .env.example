# ProxyEngine — environment configuration template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#   cp .env.example .env

# --- Data mode (NDA-safe defaults) ---
# USE_MOCK_PANEL=1          # synthetic demo panel (default; safe for git/CI)
# USE_MOCK_PANEL=0
# USE_CONFIDENTIAL_PANEL=1  # only on local machine with Chair-approved data
# CONFIDENTIAL_DATA_DIR=/path/to/Chair-approved/Data
# CONFIDENTIAL_PREDICTIONS_PATH=/path/to/local/ozkan_predictions.json

# --- DeepSeek (all AI generation: PDF extraction, /api/insight, /api/chat) ---
# Required to enable AI generation; without it the app uses deterministic templates.
# Only use with public PDFs and filtered trace payloads — never paste raw panel data.
DEEPSEEK_API_KEY=
# Optional overrides (defaults shown):
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_MAX_TOKENS=600
