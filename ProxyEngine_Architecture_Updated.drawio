        <mxCell id="anj8r9etqsJZ6B1hXlaY-23" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;" value="3. EvidenceTrace JSON&#10;(Strict, typed numeric payload.&#10;No Prose. No Hallucinations.)" vertex="1">
