        <mxCell id="WM4isf5iBtK8rN7JYO4I-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Selecting Firm&amp;nbsp;" vertex="1">
          <mxGeometry height="60" width="110" x="257.5" y="200" as="geometry" />
        </mxCell>
        <mxCell id="WM4isf5iBtK8rN7JYO4I-8" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;font style=&quot;font-size: 7px;&quot;&gt;We need the characteristcs of the company to tailor the analysis to the firm&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 7px;&quot;&gt;Eg. size and board member role&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 7px;&quot;&gt;User enters data we dont already have. &lt;b&gt;Provide automated data entry trough pdf or doc processing ?&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="112.5" width="112.5" x="257.5" y="270" as="geometry" />
        </mxCell>
        <mxCell id="anj8r9etqsJZ6B1hXlaY-21" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" value="1. Data Ingestion&#10;ORBIS (15-yr Financials)&#10;+ Compensation Targets" vertex="1">
